			)
		formatString: 0
		lineageTag: da4a284e-b830-414b-b520-e0074a4d41ef

		changedProperty = Name

	measure 'Total Cost' =
			
			SUM(
			internetsales[TotalProductCost]
			)
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: d95900bf-6114-40de-b6f4-c2acc255927c

		changedProperty = Name

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Gross Profit' =
			
			[Total Revenue]
			-
			[Total Cost]
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: a29e5492-7d55-42b2-9d20-d3df0f212698

		changedProperty = Name

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Profit Margin' =
			
			DIVIDE(
			[Gross Profit],
			[Total Revenue]
			)
		lineageTag: bd263f39-7676-4516-a67c-ce7b0ddce1b0

		changedProperty = Name

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Freight' =
			
