table internetsales
	lineageTag: c360dfe9-683c-4529-88d8-3e4edb3d57aa
	sourceLineageTag: [dbo].[internetsales]

	measure 'Total Revenue' =
			
			SUM(internetsales[SalesAmount])
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 386e8950-533f-40c2-a321-1c720c4204df

		changedProperty = Name

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Total Orders' =
			
			DISTINCTCOUNT(
			internetsales[SalesOrderNumber]
			)
		formatString: 0
		lineageTag: 4c27f2a3-1841-469d-aeff-8e36a8466c67

		changedProperty = Name

	measure 'Products Sold Quantity' =
			
			SUM(
